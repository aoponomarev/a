# Bundle artefacts (Android shell-updater)
d/a/v/*.zip binary
d/a/manifest.json text eol=lf
d/a/manifest.json.sig binary
d/a/public-key.pem text eol=lf

# Datasets archive (append-only ndjson from datasets-archiver Worker)
data/metrics/**/*.ndjson binary

# Defaults
* text=auto eol=lf
*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.js text working-tree-encoding=UTF-8
*.ts text working-tree-encoding=UTF-8
*.jsonl text working-tree-encoding=UTF-8
*.html text working-tree-encoding=UTF-8
*.css text working-tree-encoding=UTF-8
*.txt text working-tree-encoding=UTF-8
*.xml text working-tree-encoding=UTF-8
